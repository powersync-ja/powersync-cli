{
  "name": "powersync",
  "description": "A CLI for managing PowerSync instances",
  "version": "0.9.2",
  "author": "POWERSYNC",
  "bin": {
    "powersync": "./bin/run.js"
  },
  "bugs": "https://github.com/powersync-ja/powersync-cli/issues",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@inquirer/prompts": "^7.2.0",
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.40",
    "@oclif/plugin-commands": "^4.1.40",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@powersync-community/sync-config-rewriter": "^0.1.3",
    "@powersync/cli-core": "workspace:*",
    "@powersync/cli-plugin-config-edit": "workspace:*",
    "@powersync/cli-plugin-docker": "workspace:*",
    "@powersync/cli-schemas": "workspace:*",
    "@powersync/management-client": "catalog:",
    "@powersync/management-types": "catalog:",
    "@powersync/service-sync-rules": "catalog:",
    "@powersync/service-types": "catalog:",
    "bson": "^7.2.0",
    "fastify": "^5.0.0",
    "jose": "^6.1.3",
    "lodash": "^4.17.23",
    "open": "^11.0.0",
    "ora": "^9.0.0",
    "ts-codec": "^1.3.0",
    "yaml": "^2"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/lodash": "^4.17.23",
    "@types/node": "^24",
    "oclif": "4.22.81",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./templates",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/powersync-ja/powersync-cli",
  "keywords": [
    "oclif"
  ],
  "license": "FSL-1.1-ALv2",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "oclif": {
    "bin": "powersync",
    "dirname": "powersync",
    "commands": "./dist/commands",
    "macos": {
      "identifier": "com.powersync.cli"
    },
    "helpClass": "./dist/help.js",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@powersync/cli-plugin-docker",
      "@powersync/cli-plugin-config-edit",
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-commands"
    ],
    "topicSeparator": " ",
    "topics": {
      "deploy": {
        "description": "[Cloud only] Deploy local config changes to the Cloud instance. Run \"powersync deploy --help\" to list subcommands."
      },
      "fetch": {
        "description": "Inspect Cloud instances and configuration (instances, config, status). Run \"powersync fetch --help\" to list subcommands."
      },
      "generate": {
        "description": "Generate client artifacts from instance/config data (schema, token). Run \"powersync generate --help\" to list subcommands."
      },
      "init": {
        "description": "Scaffold a new PowerSync project configuration from templates. Run \"powersync init --help\" to list subcommands."
      },
      "link": {
        "description": "Bind this directory to a Cloud or self-hosted instance (writes cli.yaml). Run \"powersync link --help\" to list subcommands."
      },
      "migrate": {
        "description": "Migrate config to newer formats (for example Sync Rules to Sync Streams). Run \"powersync migrate --help\" to list subcommands."
      },
      "pull": {
        "description": "[Cloud only] Download Cloud instance configuration into local files. Run \"powersync pull --help\" to list subcommands."
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/powersync-ja/powersync-cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx bin/dev.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "pretest": "pnpm run build",
    "readme:generate": "oclif readme && pnpm exec prettier --write README.md",
    "prepack": "oclif manifest && pnpm run readme:generate",
    "test": "vitest",
    "version": "pnpm run readme:generate && git add README.md"
  },
  "types": "dist/index.d.ts"
}
