{
  "name": "@powersync/cli-schemas",
  "description": "PowerSync CLI schema definitions and JSON Schema generation",
  "version": "0.9.3",
  "author": "POWERSYNC",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "json-schema"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli-config-schema.json": "./json-schema/cli-config.json",
    "./link-config-schema.json": "./json-schema/cli-config.json",
    "./service-config-schema.json": "./json-schema/service-config.json",
    "./sync-config-schema.json": "./json-schema/sync-config.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/powersync-ja/powersync-cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": "https://github.com/powersync-ja/powersync-cli/issues",
  "scripts": {
    "build": "tsc -b && node dist/scripts/create-schemas.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint ."
  },
  "dependencies": {
    "@powersync/management-types": "catalog:",
    "@powersync/service-schema": "catalog:",
    "@powersync/service-types": "catalog:",
    "ajv": "^8.12.0",
    "better-ajv-errors": "^2.0.3",
    "ts-codec": "^1.3.0"
  },
  "devDependencies": {
    "@powersync/service-sync-rules": "catalog:",
    "@types/node": "^22",
    "shx": "^0.3.3",
    "tsx": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
