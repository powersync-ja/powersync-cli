    "@journeyapps-labs/common-sdk": "1.0.2",
    "@powersync/management-client": "^0.0.4",
    "@powersync/management-types": "^0.0.3",
    "@powersync/service-client": "^0.0.3",
    "keychain": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "typescript": "^5",
    "@types/keychain": "^1.4.4"
  },
  "engines": {
    "node": ">=18.0.0"
