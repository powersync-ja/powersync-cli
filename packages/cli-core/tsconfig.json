{
  "compilerOptions": {
    "declaration": true,
    "module": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "es2022",
    "moduleResolution": "node16",
    "sourceMap": true,
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*"],
  "references": [{ "path": "../schemas" }]
}
