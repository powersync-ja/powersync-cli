{
  "compilerOptions": {
    "declaration": true,
    "module": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "es2022",
    "moduleResolution": "node16",
    "composite": true,
    "paths": {
      "@syncpoint/wkx": ["./src/syncpoint-wkx.d.ts"]
    }
  },
  "skipLibCheck": true,
  "include": ["./src/**/*"],
  "references": [{ "path": "../schemas" }],
  "ts-node": {
    "esm": true
  }
}
