{
  "name": "@powersync/cli-plugin-docker",
  "description": "PowerSync CLI plugin: reset, start, and stop self-hosted instances using Docker Compose",
  "version": "0.9.0",
  "author": "POWERSYNC",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "oclif.manifest.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powersync-ja/powersync-cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": "https://github.com/powersync-ja/powersync-cli/issues",
  "scripts": {
    "build": "tsc -b && node scripts/copy-template-resources.mjs",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "prepack": "oclif manifest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@oclif/core": "^4",
    "@powersync/cli-core": "workspace:*",
    "@powersync/cli-schemas": "workspace:*",
    "@powersync/service-types": "^0.15.0",
    "@powersync/service-schema": "^1.20.0",
    "yaml": "^2"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9",
    "oclif": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "oclif": {
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "docker": {
        "description": "[Self-hosted only] Manage self-hosted PowerSync with Docker Compose (configure, reset, start, stop). Run \"powersync docker --help\" to list subcommands."
      }
    }
  }
}
